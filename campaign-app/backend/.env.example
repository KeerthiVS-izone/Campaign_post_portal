# Copy this file to .env and fill in your values
# cp .env.example .env

DB_HOST=localhost
DB_PORT=5432
DB_NAME=campaign_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Schema = namespace inside PostgreSQL (usually same as DB_NAME)
DB_SCHEMA=campaign_db

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
